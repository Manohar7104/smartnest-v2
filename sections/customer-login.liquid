<section class="customer-auth page-transition-surface" aria-labelledby="CustomerLoginTitle-{{ section.id }}">
  <div class="customer-auth__container">
    <div class="customer-auth__intro">
      <p class="customer-auth__eyebrow">SmartNest account</p>
      <h1 id="CustomerLoginTitle-{{ section.id }}">Sign in</h1>
      <p>Access orders, saved addresses, and account details for a smoother SmartNest checkout.</p>
    </div>

    {% if shop.customer_accounts_enabled %}
      <div class="customer-auth__grid">
        <div class="customer-auth__panel" id="login">
          <h2>Customer login</h2>

          {% form 'customer_login', class: 'customer-auth__form' %}
            {% if form.errors %}
              <div class="customer-auth__message customer-auth__message--error" role="alert" tabindex="-1">
                {{ form.errors | default_errors }}
              </div>
            {% endif %}

            <div class="customer-auth__field">
              <label for="CustomerEmail-{{ section.id }}">Email</label>
              <input
                id="CustomerEmail-{{ section.id }}"
                type="email"
                name="customer[email]"
                autocomplete="email"
                autocorrect="off"
                autocapitalize="off"
                required
                {% if form.errors contains 'email' %}aria-invalid="true"{% endif %}
              >
            </div>

            {% if form.password_needed %}
              <div class="customer-auth__field">
                <div class="customer-auth__label-row">
                  <label for="CustomerPassword-{{ section.id }}">Password</label>
                  <a href="#recover" class="customer-auth__inline-link">Forgot password?</a>
                </div>
                <input
                  id="CustomerPassword-{{ section.id }}"
                  type="password"
                  name="customer[password]"
                  autocomplete="current-password"
                  required
                  {% if form.errors contains 'password' %}aria-invalid="true"{% endif %}
                >
              </div>
            {% endif %}

            <button type="submit" class="customer-auth__button">Sign in</button>
          {% endform %}

          <p class="customer-auth__switch">
            New to SmartNest?
            <a href="{{ routes.account_register_url }}">Create an account</a>
          </p>
        </div>

        <div class="customer-auth__panel" id="recover">
          <h2>Reset your password</h2>
          <p class="customer-auth__help">Enter your email and Shopify will send password reset instructions.</p>

          {% form 'recover_customer_password', class: 'customer-auth__form' %}
            {% if form.posted_successfully? %}
              <div class="customer-auth__message customer-auth__message--success" role="status" tabindex="-1">
                We have sent you an email with a link to update your password.
              </div>
            {% endif %}

            {% if form.errors %}
              <div class="customer-auth__message customer-auth__message--error" role="alert" tabindex="-1">
                {{ form.errors | default_errors }}
              </div>
            {% endif %}

            <div class="customer-auth__field">
              <label for="RecoverEmail-{{ section.id }}">Email</label>
              <input
                id="RecoverEmail-{{ section.id }}"
                type="email"
                name="email"
                autocomplete="email"
                autocorrect="off"
                autocapitalize="off"
                required
                {% if form.errors %}aria-invalid="true"{% endif %}
              >
            </div>

            <div class="customer-auth__actions">
              <button type="submit" class="customer-auth__button">Send reset email</button>
              <a href="#login" class="customer-auth__secondary-link">Back to login</a>
            </div>
          {% endform %}
        </div>
      </div>
    {% else %}
      <div class="customer-auth__panel">
        <p class="customer-auth__message customer-auth__message--error" role="status">
          Customer accounts are currently disabled for this store.
        </p>
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .customer-auth {
    --account-accent: #14594b;
    color: #16231f;
    padding-block: clamp(36px, 7vw, 88px);
  }

  .page-transition-surface {
    will-change: opacity, transform;
  }

  .customer-auth__container {
    width: min(1040px, calc(100% - 32px));
    margin-inline: auto;
  }

  .customer-auth__intro {
    max-width: 680px;
    margin-bottom: 28px;
  }

  .customer-auth__eyebrow {
    margin: 0 0 8px;
    color: var(--account-accent);
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .customer-auth h1 {
    margin: 0 0 12px;
    font-size: clamp(2.1rem, 5vw, 3.6rem);
    line-height: 1;
  }

  .customer-auth__intro p:last-child,
  .customer-auth__help,
  .customer-auth__switch {
    color: rgba(22, 35, 31, 0.68);
    line-height: 1.6;
  }

  .customer-auth__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.82fr);
    gap: 22px;
    align-items: start;
  }

  .customer-auth__panel {
    display: grid;
    gap: 18px;
    border: 1px solid rgba(20, 89, 75, 0.14);
    border-radius: 8px;
    background: #ffffff;
    padding: clamp(20px, 4vw, 32px);
    box-shadow: 0 14px 34px rgba(20, 89, 75, 0.08);
  }

  .customer-auth__panel h2 {
    margin: 0;
    font-size: clamp(1.35rem, 3vw, 1.8rem);
  }

  .customer-auth__form,
  .customer-auth__field {
    display: grid;
    gap: 12px;
  }

  .customer-auth__field label,
  .customer-auth__label-row {
    font-weight: 900;
  }

  .customer-auth__label-row {
    display: flex;
    justify-content: space-between;
    gap: 16px;
  }

  .customer-auth__field input {
    width: 100%;
    min-height: 48px;
    border: 1px solid rgba(20, 89, 75, 0.2);
    border-radius: 8px;
    padding: 12px 14px;
    background: #ffffff;
    color: inherit;
  }

  .customer-auth__field input:focus-visible {
    border-color: var(--account-accent);
    outline: 2px solid rgba(20, 89, 75, 0.24);
    outline-offset: 2px;
  }

  .customer-auth__button {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 8px;
    background: var(--account-accent);
    color: #ffffff;
    cursor: pointer;
    padding: 12px 18px;
    font-weight: 900;
    text-decoration: none;
    transition: transform 160ms ease, opacity 160ms ease;
  }

  .customer-auth__button:hover {
    transform: translateY(-1px);
  }

  .customer-auth__inline-link,
  .customer-auth__secondary-link,
  .customer-auth__switch a {
    color: var(--account-accent);
    font-weight: 900;
  }

  .customer-auth__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
  }

  .customer-auth__message {
    border-radius: 8px;
    padding: 12px 14px;
    line-height: 1.5;
  }

  .customer-auth__message--error {
    background: #ffe4e6;
    color: #9f1239;
  }

  .customer-auth__message--success {
    background: #dcfce7;
    color: #166534;
  }

  @media (max-width: 779px) {
    .customer-auth__grid {
      grid-template-columns: 1fr;
    }

    .customer-auth__container {
      width: min(100% - 24px, 1040px);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Customer login",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
