<section class="customer-auth page-transition-surface" aria-labelledby="CustomerRegisterTitle-{{ section.id }}">
  <div class="customer-auth__container">
    <div class="customer-auth__intro">
      <p class="customer-auth__eyebrow">SmartNest account</p>
      <h1 id="CustomerRegisterTitle-{{ section.id }}">Create an account</h1>
      <p>Save your details, view orders, and make repeat checkout faster.</p>
    </div>

    {% if shop.customer_accounts_enabled %}
      <div class="customer-auth__panel customer-auth__panel--narrow">
        {% form 'create_customer', class: 'customer-auth__form' %}
          {% if form.errors %}
            <div class="customer-auth__message customer-auth__message--error" role="alert" tabindex="-1">
              {{ form.errors | default_errors }}
            </div>
          {% endif %}

          <div class="customer-auth__split">
            <div class="customer-auth__field">
              <label for="RegisterFirstName-{{ section.id }}">First name</label>
              <input
                id="RegisterFirstName-{{ section.id }}"
                type="text"
                name="customer[first_name]"
                autocomplete="given-name"
                value="{{ form.first_name | escape }}"
              >
            </div>

            <div class="customer-auth__field">
              <label for="RegisterLastName-{{ section.id }}">Last name</label>
              <input
                id="RegisterLastName-{{ section.id }}"
                type="text"
                name="customer[last_name]"
                autocomplete="family-name"
                value="{{ form.last_name | escape }}"
              >
            </div>
          </div>

          <div class="customer-auth__field">
            <label for="RegisterEmail-{{ section.id }}">Email</label>
            <input
              id="RegisterEmail-{{ section.id }}"
              type="email"
              name="customer[email]"
              autocomplete="email"
              autocorrect="off"
              autocapitalize="off"
              value="{{ form.email | escape }}"
              required
              {% if form.errors contains 'email' %}aria-invalid="true"{% endif %}
            >
          </div>

          <div class="customer-auth__field">
            <label for="RegisterPassword-{{ section.id }}">Password</label>
            <input
              id="RegisterPassword-{{ section.id }}"
              type="password"
              name="customer[password]"
              autocomplete="new-password"
              required
              {% if form.errors contains 'password' %}aria-invalid="true"{% endif %}
            >
          </div>

          <button type="submit" class="customer-auth__button">Create account</button>
        {% endform %}

        <p class="customer-auth__switch">
          Already have an account?
          <a href="{{ routes.account_login_url }}">Sign in</a>
        </p>
      </div>
    {% else %}
      <div class="customer-auth__panel customer-auth__panel--narrow">
        <p class="customer-auth__message customer-auth__message--error" role="status">
          Customer accounts are currently disabled for this store.
        </p>
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .customer-auth {
    --account-accent: #14594b;
    color: #16231f;
    padding-block: clamp(36px, 7vw, 88px);
  }

  .page-transition-surface {
    will-change: opacity, transform;
  }

  .customer-auth__container {
    width: min(1040px, calc(100% - 32px));
    margin-inline: auto;
  }

  .customer-auth__intro {
    max-width: 680px;
    margin-bottom: 28px;
  }

  .customer-auth__eyebrow {
    margin: 0 0 8px;
    color: var(--account-accent);
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .customer-auth h1 {
    margin: 0 0 12px;
    font-size: clamp(2.1rem, 5vw, 3.6rem);
    line-height: 1;
  }

  .customer-auth__intro p:last-child,
  .customer-auth__switch {
    color: rgba(22, 35, 31, 0.68);
    line-height: 1.6;
  }

  .customer-auth__panel {
    display: grid;
    gap: 18px;
    border: 1px solid rgba(20, 89, 75, 0.14);
    border-radius: 8px;
    background: #ffffff;
    padding: clamp(20px, 4vw, 32px);
    box-shadow: 0 14px 34px rgba(20, 89, 75, 0.08);
  }

  .customer-auth__panel--narrow {
    max-width: 680px;
  }

  .customer-auth__form,
  .customer-auth__field {
    display: grid;
    gap: 12px;
  }

  .customer-auth__split {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 16px;
  }

  .customer-auth__field label {
    font-weight: 900;
  }

  .customer-auth__field input {
    width: 100%;
    min-height: 48px;
    border: 1px solid rgba(20, 89, 75, 0.2);
    border-radius: 8px;
    padding: 12px 14px;
    background: #ffffff;
    color: inherit;
  }

  .customer-auth__field input:focus-visible {
    border-color: var(--account-accent);
    outline: 2px solid rgba(20, 89, 75, 0.24);
    outline-offset: 2px;
  }

  .customer-auth__button {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 8px;
    background: var(--account-accent);
    color: #ffffff;
    cursor: pointer;
    padding: 12px 18px;
    font-weight: 900;
    text-decoration: none;
    transition: transform 160ms ease, opacity 160ms ease;
  }

  .customer-auth__button:hover {
    transform: translateY(-1px);
  }

  .customer-auth__switch a {
    color: var(--account-accent);
    font-weight: 900;
  }

  .customer-auth__message {
    border-radius: 8px;
    padding: 12px 14px;
    line-height: 1.5;
  }

  .customer-auth__message--error {
    background: #ffe4e6;
    color: #9f1239;
  }

  @media (max-width: 679px) {
    .customer-auth__container {
      width: min(100% - 24px, 1040px);
    }

    .customer-auth__split {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Customer register",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
