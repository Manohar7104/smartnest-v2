{% liquid
  assign current_variant = product.selected_or_first_available_variant
  assign recommendations_source = product.collections.first
%}

{% render 'breadcrumbs', product: product %}

<section class="product-page page-transition-surface" data-product-root>
  <div class="product-container">
    <div class="product-media">
      <div class="product-media__featured">
        {% if product.featured_image != blank %}
          {{
            product.featured_image
            | image_url: width: 1000
            | image_tag:
              class: 'product-media__image',
              widths: '400, 600, 800, 1000',
              sizes: '(min-width: 990px) 50vw, 100vw',
              loading: 'eager',
              fetchpriority: 'high',
              alt: product.featured_image.alt | default: product.title
          }}
        {% else %}
          {{ 'product-1' | placeholder_svg_tag: 'product-media__placeholder' }}
        {% endif %}
      </div>

      {% if product.media.size > 1 %}
        <div class="product-media__thumbs" aria-label="Product images">
          {% for media in product.media %}
            {% if media.media_type == 'image' %}
              <button
                type="button"
                class="product-media__thumb{% if media.id == product.featured_media.id %} is-active{% endif %}"
                data-product-thumbnail
                data-image-src="{{ media.preview_image | image_url: width: 1000 }}"
                data-image-alt="{{ media.preview_image.alt | default: product.title | escape }}"
                aria-label="Show image {{ forloop.index }} for {{ product.title | escape }}"
                aria-pressed="{% if media.id == product.featured_media.id %}true{% else %}false{% endif %}"
              >
                {{
                  media.preview_image
                  | image_url: width: 160
                  | image_tag:
                    widths: '80, 120, 160',
                    sizes: '80px',
                    loading: 'lazy',
                    alt: media.preview_image.alt | default: product.title
                }}
              </button>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="product-info">
      {% if product.vendor != blank %}
        <p class="product-info__vendor">{{ product.vendor | escape }}</p>
      {% endif %}

      <h1 class="product-info__title">{{ product.title | escape }}</h1>

      <div class="product-info__price-section" data-price-section>
        <div class="product-info__price">
          <span data-product-price>{{ current_variant.price | money }}</span>
          <s
            class="product-info__compare-price{% unless current_variant.compare_at_price > current_variant.price %} is-hidden{% endunless %}"
            data-product-compare-price
          >
            {{ current_variant.compare_at_price | money }}
          </s>
        </div>

        <p
          class="product-info__stock {% if current_variant.available %}product-info__stock--available{% else %}product-info__stock--unavailable{% endif %}"
          data-product-inventory
          role="status"
        >
          {% if current_variant.available %}
            {{ 'product.available' | t }}
          {% else %}
            {{ 'product.unavailable' | t }}
          {% endif %}
        </p>
      </div>

      {% if product.description != blank %}
        <div class="product-info__description rte">{{ product.description }}</div>
      {% endif %}

      {% form 'product', product, class: 'product-form' %}
        <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id-input>

        {% unless product.has_only_default_variant %}
          <div class="product-form__options">
            {% for option in product.options_with_values %}
              <fieldset class="product-form__fieldset">
                <legend class="product-form__legend">{{ option.name }}</legend>

                <div class="product-form__values">
                  {% for value in option.values %}
                    {% liquid
                      assign option_position = option.position | minus: 1
                      assign checked = false
                      if current_variant.options[option_position] == value
                        assign checked = true
                      endif
                    %}
                    <label class="product-form__choice">
                      <input
                        type="radio"
                        name="options[{{ option.name | escape }}]"
                        value="{{ value | escape }}"
                        data-option-position="{{ option.position }}"
                        {% if checked %}checked{% endif %}
                      >
                      <span>{{ value }}</span>
                    </label>
                  {% endfor %}
                </div>
              </fieldset>
            {% endfor %}
          </div>
        {% endunless %}

        <div class="product-form__quantity">
          <label for="ProductQuantity-{{ section.id }}">{{ 'product.quantity' | t }}</label>
          <div class="quantity-stepper" data-quantity-stepper>
            <button type="button" class="quantity-stepper__button" data-quantity-decrease aria-label="Decrease quantity">−</button>
            <input
              id="ProductQuantity-{{ section.id }}"
              class="quantity-stepper__input"
              type="number"
              name="quantity"
              min="1"
              value="1"
              inputmode="numeric"
              data-quantity-input
            >
            <button type="button" class="quantity-stepper__button" data-quantity-increase aria-label="Increase quantity">+</button>
          </div>
        </div>

        <button
          type="submit"
          class="product-form__button"
          data-add-to-cart-button
          {% unless current_variant.available %}disabled{% endunless %}
        >
          {% if current_variant.available %}
            {{ 'product.add_to_cart' | t }}
          {% else %}
            {{ 'product.unavailable' | t }}
          {% endif %}
        </button>

        {{ form | payment_button }}

        {% if form.errors %}
          <div class="product-form__errors" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}
      {% endform %}

      <dl class="product-info__meta">
        <div>
          <dt>{{ 'product.sku' | t }}</dt>
          <dd data-product-sku>{{ current_variant.sku | default: 'N/A' }}</dd>
        </div>
        {% if product.type != blank %}
          <div>
            <dt>Type</dt>
            <dd>{{ product.type | escape }}</dd>
          </div>
        {% endif %}
      </dl>
    </div>
  </div>

  {% if recommendations_source != blank and recommendations_source.products_count > 1 %}
    <div class="product-recommendations" aria-labelledby="ProductRecommendations-{{ section.id }}">
      <div class="product-recommendations__header">
        <p class="product-recommendations__eyebrow">You may also like</p>
        <h2 id="ProductRecommendations-{{ section.id }}">Product recommendations</h2>
      </div>

      <div class="product-recommendations__grid">
        {% assign shown_recommendations = 0 %}
        {% for recommendation in recommendations_source.products %}
          {% if recommendation.id != product.id and shown_recommendations < 4 %}
            {% assign shown_recommendations = shown_recommendations | plus: 1 %}
            <article class="recommended-product">
              <a class="recommended-product__image" href="{{ recommendation.url }}">
                {% if recommendation.featured_image != blank %}
                  {{
                    recommendation.featured_image
                    | image_url: width: 600
                    | image_tag:
                      widths: '260, 400, 600',
                      sizes: '(min-width: 990px) 25vw, 50vw',
                      loading: 'lazy',
                      alt: recommendation.featured_image.alt | default: recommendation.title
                  }}
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'recommended-product__placeholder' }}
                {% endif %}
              </a>
              <div class="recommended-product__content">
                <h3><a href="{{ recommendation.url }}">{{ recommendation.title | escape }}</a></h3>
                <p>{{ recommendation.price | money }}</p>
              </div>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  {% endif %}

  <div class="recently-viewed-inline" data-recently-viewed-section hidden>
    <div class="product-recommendations__header">
      <p class="product-recommendations__eyebrow">Recently viewed</p>
      <h2>Continue where you left off</h2>
    </div>
    <div class="product-recommendations__grid" data-recently-viewed-grid></div>
  </div>

  <script type="application/json" data-product-json>
    {{ product | json }}
  </script>

  <script type="application/json" data-product-money-format>
    {{ shop.money_format | json }}
  </script>

  <div
    data-product-id="{{ product.id }}"
    data-product-title="{{ product.title | escape }}"
    data-product-url="{{ product.url }}"
    data-product-price="{{ current_variant.price | money }}"
    data-product-image="{% if product.featured_image != blank %}{{ product.featured_image | image_url: width: 400 }}{% endif %}"
    hidden
  ></div>
</section>

{% stylesheet %}
  .product-page {
    --product-accent: #14594b;
    color: #16231f;
  }

  .page-transition-surface {
    will-change: opacity, transform;
  }

  .product-container,
  .product-recommendations,
  .recently-viewed-inline {
    width: min(1180px, calc(100% - 32px));
    margin-inline: auto;
  }

  .product-container {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.86fr);
    gap: clamp(28px, 5vw, 64px);
    align-items: start;
    padding-block: clamp(32px, 6vw, 72px);
  }

  .product-media__featured,
  .product-media__thumb,
  .recommended-product__image {
    background: #eef4f0;
    border-radius: 8px;
    overflow: hidden;
  }

  .product-media__featured {
    aspect-ratio: 1;
  }

  .product-media__image,
  .product-media__placeholder,
  .recommended-product__image img,
  .recommended-product__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-media__image {
    transition: transform 220ms ease;
  }

  .product-media__featured:hover .product-media__image {
    transform: scale(1.035);
  }

  .product-media__thumbs {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(72px, 1fr));
    gap: 10px;
    margin-top: 12px;
  }

  .product-media__thumb {
    aspect-ratio: 1;
    border: 2px solid transparent;
    cursor: pointer;
    padding: 0;
  }

  .product-media__thumb.is-active,
  .product-media__thumb:focus-visible {
    border-color: var(--product-accent);
    outline: none;
  }

  .product-info {
    position: sticky;
    top: 96px;
  }

  .product-info__vendor {
    margin: 0 0 8px;
    color: var(--product-accent);
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .product-info__title {
    margin: 0 0 18px;
    font-size: clamp(2rem, 5vw, 3.7rem);
    line-height: 1.02;
  }

  .product-info__price-section {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
    margin-bottom: 22px;
  }

  .product-info__price {
    display: flex;
    gap: 10px;
    align-items: baseline;
  }

  [data-product-price] {
    color: var(--product-accent);
    font-size: 1.35rem;
    font-weight: 900;
  }

  .product-info__compare-price {
    color: rgba(22, 35, 31, 0.48);
  }

  .is-hidden {
    display: none !important;
  }

  .product-info__stock {
    margin: 0;
    border-radius: 999px;
    padding: 7px 11px;
    font-size: 0.82rem;
    font-weight: 800;
  }

  .product-info__stock--available {
    background: #dcfce7;
    color: #166534;
  }

  .product-info__stock--unavailable {
    background: #ffe4e6;
    color: #9f1239;
  }

  .product-info__description {
    color: rgba(22, 35, 31, 0.74);
    line-height: 1.7;
    margin-bottom: 24px;
  }

  .product-form {
    display: grid;
    gap: 20px;
  }

  .product-form__fieldset {
    border: 0;
    margin: 0;
    padding: 0;
  }

  .product-form__legend,
  .product-form__quantity label {
    display: block;
    margin-bottom: 10px;
    font-weight: 900;
  }

  .product-form__values {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .product-form__choice input {
    position: absolute;
    opacity: 0;
  }

  .product-form__choice span {
    display: inline-flex;
    min-height: 42px;
    align-items: center;
    border: 1px solid rgba(20, 89, 75, 0.22);
    border-radius: 8px;
    padding: 10px 14px;
    cursor: pointer;
    font-weight: 800;
  }

  .product-form__choice input:checked + span,
  .product-form__choice input:focus-visible + span {
    border-color: var(--product-accent);
    box-shadow: 0 0 0 2px rgba(20, 89, 75, 0.16);
  }

  .quantity-stepper {
    display: inline-grid;
    grid-template-columns: 42px 70px 42px;
    min-height: 44px;
    border: 1px solid rgba(20, 89, 75, 0.22);
    border-radius: 8px;
    overflow: hidden;
  }

  .quantity-stepper__button {
    border: 0;
    background: #f7fbf8;
    color: var(--product-accent);
    cursor: pointer;
    font-size: 1.1rem;
    font-weight: 900;
  }

  .quantity-stepper__input {
    border: 0;
    border-inline: 1px solid rgba(20, 89, 75, 0.16);
    text-align: center;
  }

  .product-form__button,
  .shopify-payment-button__button {
    min-height: 50px;
    border: 0;
    border-radius: 8px;
    background: var(--product-accent);
    color: #ffffff;
    cursor: pointer;
    font-weight: 900;
    transition: transform 160ms ease, opacity 160ms ease;
  }

  .product-form__button:hover,
  .shopify-payment-button__button:hover,
  .recommended-product:hover {
    transform: translateY(-2px);
  }

  .product-form__button:disabled {
    cursor: not-allowed;
    opacity: 0.55;
  }

  .product-info__meta {
    display: grid;
    gap: 8px;
    margin-top: 24px;
    border-top: 1px solid rgba(20, 89, 75, 0.14);
    padding-top: 18px;
  }

  .product-info__meta div {
    display: flex;
    justify-content: space-between;
    gap: 20px;
  }

  .product-info__meta dt {
    color: rgba(22, 35, 31, 0.58);
    font-weight: 800;
  }

  .product-info__meta dd {
    margin: 0;
  }

  .product-recommendations,
  .recently-viewed-inline {
    padding-block: clamp(36px, 6vw, 72px);
  }

  .product-recommendations__header {
    margin-bottom: 24px;
  }

  .product-recommendations__eyebrow {
    margin: 0 0 8px;
    color: var(--product-accent);
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .product-recommendations h2,
  .recently-viewed-inline h2 {
    margin: 0;
    font-size: clamp(1.8rem, 4vw, 2.7rem);
  }

  .product-recommendations__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
  }

  .recommended-product {
    border: 1px solid rgba(20, 89, 75, 0.12);
    border-radius: 8px;
    overflow: hidden;
    transition: transform 160ms ease, box-shadow 160ms ease;
  }

  .recommended-product:hover {
    box-shadow: 0 16px 36px rgba(20, 89, 75, 0.12);
  }

  .recommended-product__image {
    display: block;
    aspect-ratio: 1;
  }

  .recommended-product__content {
    padding: 14px;
  }

  .recommended-product h3 {
    margin: 0 0 8px;
    font-size: 1rem;
    line-height: 1.35;
  }

  .recommended-product h3 a {
    color: inherit;
    text-decoration: none;
  }

  .recommended-product p {
    margin: 0;
    color: var(--product-accent);
    font-weight: 900;
  }

  @media (max-width: 989px) {
    .product-container {
      grid-template-columns: 1fr;
    }

    .product-info {
      position: static;
    }

    .product-recommendations__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 639px) {
    .product-container,
    .product-recommendations,
    .recently-viewed-inline {
      width: min(100% - 24px, 1180px);
    }

    .product-recommendations__grid {
      grid-template-columns: 1fr;
    }

    .product-form__button,
    .shopify-payment-button__button {
      width: 100%;
    }
  }
{% endstylesheet %}

{% javascript %}
  (() => {
    const STORAGE_KEY = 'smartnest_recently_viewed';
    const MAX_RECENT = 6;

    const formatMoney = (cents, format) => {
      if (window.Shopify && typeof window.Shopify.formatMoney === 'function') {
        return window.Shopify.formatMoney(cents, format);
      }

      return new Intl.NumberFormat(document.documentElement.lang || 'en', {
        style: 'currency',
        currency: window.Shopify?.currency?.active || 'USD'
      }).format(cents / 100);
    };

    document.querySelectorAll('[data-product-root]').forEach((root) => {
      const productJson = root.querySelector('[data-product-json]');
      const moneyJson = root.querySelector('[data-product-money-format]');
      const form = root.querySelector('.product-form');
      const variantIdInput = root.querySelector('[data-variant-id-input]');
      const priceEl = root.querySelector('[data-product-price]');
      const comparePriceEl = root.querySelector('[data-product-compare-price]');
      const inventoryEl = root.querySelector('[data-product-inventory]');
      const skuEl = root.querySelector('[data-product-sku]');
      const addButton = root.querySelector('[data-add-to-cart-button]');
      const mainImage = root.querySelector('.product-media__image');
      const quantityInput = root.querySelector('[data-quantity-input]');

      if (!productJson || !form) return;

      const product = JSON.parse(productJson.textContent);
      const moneyFormat = moneyJson ? JSON.parse(moneyJson.textContent) : '';

      const selectedOptions = () => {
        return Array.from(root.querySelectorAll('[data-option-position]'))
          .filter((input) => input.checked)
          .sort((a, b) => Number(a.dataset.optionPosition) - Number(b.dataset.optionPosition))
          .map((input) => input.value);
      };

      const findVariant = () => {
        const options = selectedOptions();
        return product.variants.find((variant) => {
          return variant.options.every((option, index) => option === options[index]);
        });
      };

      const setAvailability = (variant) => {
        if (!variant) {
          addButton.disabled = true;
          addButton.textContent = 'Unavailable';
          inventoryEl.textContent = 'Unavailable';
          inventoryEl.className = 'product-info__stock product-info__stock--unavailable';
          return;
        }

        addButton.disabled = !variant.available;
        addButton.textContent = variant.available ? 'Add to cart' : 'Sold out';
        inventoryEl.textContent = variant.available ? 'In stock' : 'Sold out';
        inventoryEl.className = variant.available
          ? 'product-info__stock product-info__stock--available'
          : 'product-info__stock product-info__stock--unavailable';
      };

      const updateVariant = () => {
        const variant = findVariant();
        if (!variant) {
          setAvailability(null);
          return;
        }

        variantIdInput.value = variant.id;
        priceEl.textContent = formatMoney(variant.price, moneyFormat);

        if (variant.compare_at_price && variant.compare_at_price > variant.price) {
          comparePriceEl.textContent = formatMoney(variant.compare_at_price, moneyFormat);
          comparePriceEl.classList.remove('is-hidden');
        } else {
          comparePriceEl.classList.add('is-hidden');
        }

        skuEl.textContent = variant.sku || 'N/A';
        setAvailability(variant);

        if (variant.featured_image && mainImage) {
          mainImage.src = `${variant.featured_image.src}&width=1000`;
          mainImage.alt = variant.featured_image.alt || product.title;
        }

        const url = new URL(window.location.href);
        url.searchParams.set('variant', variant.id);
        window.history.replaceState({}, '', url.toString());
      };

      root.querySelectorAll('[data-option-position]').forEach((input) => {
        input.addEventListener('change', updateVariant);
      });

      root.querySelectorAll('[data-product-thumbnail]').forEach((button) => {
        button.addEventListener('click', () => {
          if (!mainImage) return;
          mainImage.src = button.dataset.imageSrc;
          mainImage.alt = button.dataset.imageAlt || product.title;
          root.querySelectorAll('[data-product-thumbnail]').forEach((thumb) => {
            thumb.classList.remove('is-active');
            thumb.setAttribute('aria-pressed', 'false');
          });
          button.classList.add('is-active');
          button.setAttribute('aria-pressed', 'true');
        });
      });

      root.querySelectorAll('[data-quantity-stepper]').forEach((stepper) => {
        const input = stepper.querySelector('[data-quantity-input]');
        stepper.querySelector('[data-quantity-decrease]')?.addEventListener('click', () => {
          input.value = Math.max(Number(input.min || 1), Number(input.value || 1) - 1);
        });
        stepper.querySelector('[data-quantity-increase]')?.addEventListener('click', () => {
          input.value = Number(input.value || 1) + 1;
        });
      });

      form.addEventListener('submit', (event) => {
        const variant = product.variants.find((item) => String(item.id) === String(variantIdInput.value));
        if (!variant || !variant.available || Number(quantityInput.value) < 1) {
          event.preventDefault();
        }
      });

      const tracker = root.querySelector('[data-product-id]');
      if (tracker) {
        const viewed = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]')
          .filter((item) => item.id !== tracker.dataset.productId);
        viewed.unshift({
          id: tracker.dataset.productId,
          title: tracker.dataset.productTitle,
          url: tracker.dataset.productUrl,
          image: tracker.dataset.productImage,
          price: tracker.dataset.productPrice
        });
        localStorage.setItem(STORAGE_KEY, JSON.stringify(viewed.slice(0, MAX_RECENT)));
      }

      const recentlyViewedSection = root.querySelector('[data-recently-viewed-section]');
      const recentlyViewedGrid = root.querySelector('[data-recently-viewed-grid]');
      if (recentlyViewedSection && recentlyViewedGrid) {
        const items = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]')
          .filter((item) => item.id !== tracker?.dataset.productId)
          .slice(0, 4);

        if (items.length > 0) {
          recentlyViewedGrid.innerHTML = items.map((item) => `
            <article class="recommended-product">
              <a class="recommended-product__image" href="${item.url}">
                ${item.image ? `<img src="${item.image}" alt="${item.title}" loading="lazy" width="400" height="400">` : ''}
              </a>
              <div class="recommended-product__content">
                <h3><a href="${item.url}">${item.title}</a></h3>
                <p>${item.price}</p>
              </div>
            </article>
          `).join('');
          recentlyViewedSection.hidden = false;
        }
      }
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Product",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
