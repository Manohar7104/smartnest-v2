{% liquid
  assign search_type = request.params.type | default: 'product,article,page,collection'
%}

{% render 'breadcrumbs' %}

<section class="search-section page-transition-surface">
  <div class="search-container">
    <div class="search-header">
      <p class="search-header__eyebrow">Search SmartNest</p>
      <h1>{{ 'search.title' | t }}</h1>
    </div>

    <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
      <input type="hidden" name="options[prefix]" value="last">

      <label class="visually-hidden" for="SearchInput-{{ section.id }}">Search</label>
      <div class="search-form__row">
        <input
          id="SearchInput-{{ section.id }}"
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="{{ 'search.placeholder' | t }}"
          class="search-input"
          autocomplete="off"
        >

        <label class="visually-hidden" for="SearchType-{{ section.id }}">Result type</label>
        <select id="SearchType-{{ section.id }}" name="type" class="search-type">
          <option value="product,article,page,collection" {% if search_type == 'product,article,page,collection' %}selected{% endif %}>Everything</option>
          <option value="product" {% if search_type == 'product' %}selected{% endif %}>Products</option>
          <option value="collection" {% if search_type == 'collection' %}selected{% endif %}>Collections</option>
          <option value="article,page" {% if search_type == 'article,page' %}selected{% endif %}>Articles and pages</option>
        </select>

        <button type="submit" class="search-button" aria-label="{{ 'search.submit' | t }}">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.35-4.35"></path>
          </svg>
          <span>{{ 'search.submit' | t }}</span>
        </button>
      </div>
    </form>

    {% if search.performed %}
      <div class="results-header" role="status">
        {% if search.results_count > 0 %}
          <h2>
            {{ search.results_count }} result{% unless search.results_count == 1 %}s{% endunless %}
            for “{{ search.terms | escape }}”
          </h2>
        {% else %}
          <h2>No results for “{{ search.terms | escape }}”</h2>
        {% endif %}
      </div>

      {% if search.results_count > 0 %}
        {% paginate search.results by section.settings.results_per_page %}
          <div class="results-grid">
            {% for result in search.results %}
              {% liquid
                assign featured_image = result.featured_image | default: result.image
              %}

              <article class="result-card">
                <a class="result-card__image" href="{{ result.url }}" aria-label="{{ result.title | escape }}">
                  {% if featured_image %}
                    {{
                      featured_image
                      | image_url: width: 700
                      | image_tag:
                        widths: '260, 420, 700',
                        sizes: '(min-width: 990px) 25vw, (min-width: 640px) 50vw, 100vw',
                        loading: 'lazy',
                        alt: featured_image.alt | default: result.title
                    }}
                  {% else %}
                    {{ 'product-1' | placeholder_svg_tag: 'result-card__placeholder' }}
                  {% endif %}
                </a>

                <div class="result-card__content">
                  <p class="result-card__type">{{ result.object_type | capitalize }}</p>
                  <h3><a href="{{ result.url }}">{{ result.title | escape }}</a></h3>

                  {% if result.object_type == 'product' %}
                    <div class="result-card__price">
                      <span>{{ result.price | money }}</span>
                      {% if result.compare_at_price > result.price %}
                        <s>{{ result.compare_at_price | money }}</s>
                      {% endif %}
                    </div>

                    {% if result.available %}
                      <span class="result-card__badge result-card__badge--available">In stock</span>
                    {% else %}
                      <span class="result-card__badge result-card__badge--unavailable">Sold out</span>
                    {% endif %}
                  {% elsif result.object_type == 'article' %}
                    <p class="result-card__meta">{{ result.published_at | date: '%B %d, %Y' }}</p>
                    {% if result.excerpt != blank %}
                      <p class="result-card__excerpt">{{ result.excerpt | strip_html | truncatewords: 24 }}</p>
                    {% endif %}
                  {% elsif result.object_type == 'collection' %}
                    <p class="result-card__meta">{{ result.all_products_count }} product{% unless result.all_products_count == 1 %}s{% endunless %}</p>
                    {% if result.description != blank %}
                      <p class="result-card__excerpt">{{ result.description | strip_html | truncatewords: 24 }}</p>
                    {% endif %}
                  {% elsif result.content != blank %}
                    <p class="result-card__excerpt">{{ result.content | strip_html | truncatewords: 24 }}</p>
                  {% endif %}

                  <a href="{{ result.url }}" class="result-card__link">View details</a>
                </div>
              </article>
            {% endfor %}
          </div>

          {% if paginate.pages > 1 %}
            <nav class="search-pagination" aria-label="Search results pagination">
              {{ paginate | default_pagination }}
            </nav>
          {% endif %}
        {% endpaginate %}
      {% else %}
        <div class="search-empty">
          <p>Try a broader term, check spelling, or browse the SmartNest catalog.</p>
          <a href="{{ routes.all_products_collection_url }}" class="search-button search-button--link">Browse all products</a>
        </div>
      {% endif %}
    {% else %}
      <div class="search-prompt">
        <p>Search for smart devices, home essentials, guides, and collections.</p>
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .search-section {
    --search-accent: #14594b;
    padding-block: clamp(32px, 6vw, 72px);
    color: #16231f;
  }

  .page-transition-surface {
    will-change: opacity, transform;
  }

  .search-container {
    width: min(1180px, calc(100% - 32px));
    margin-inline: auto;
  }

  .search-header {
    max-width: 760px;
    margin: 0 auto 28px;
    text-align: center;
  }

  .search-header__eyebrow {
    margin: 0 0 8px;
    color: var(--search-accent);
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .search-header h1 {
    margin: 0;
    font-size: clamp(2.2rem, 6vw, 4.2rem);
    line-height: 1;
  }

  .search-form {
    max-width: 860px;
    margin: 0 auto clamp(28px, 5vw, 52px);
  }

  .search-form__row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 180px auto;
    gap: 10px;
    border: 1px solid rgba(20, 89, 75, 0.16);
    border-radius: 8px;
    background: #ffffff;
    padding: 8px;
    box-shadow: 0 16px 40px rgba(20, 89, 75, 0.08);
  }

  .search-input,
  .search-type {
    min-height: 46px;
    border: 0;
    background: #f7fbf8;
    color: #16231f;
    padding: 10px 12px;
  }

  .search-input:focus,
  .search-type:focus {
    outline: 2px solid rgba(20, 89, 75, 0.22);
    outline-offset: 2px;
  }

  .search-button {
    display: inline-flex;
    min-height: 46px;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border: 0;
    border-radius: 8px;
    background: var(--search-accent);
    color: #ffffff;
    cursor: pointer;
    padding: 10px 16px;
    font-weight: 900;
    text-decoration: none;
  }

  .search-button--link {
    width: fit-content;
  }

  .results-header {
    margin-bottom: 24px;
    text-align: center;
  }

  .results-header h2 {
    margin: 0;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
  }

  .result-card {
    border: 1px solid rgba(20, 89, 75, 0.12);
    border-radius: 8px;
    overflow: hidden;
    background: #ffffff;
    transition: transform 160ms ease, box-shadow 160ms ease;
  }

  .result-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 16px 36px rgba(20, 89, 75, 0.12);
  }

  .result-card__image {
    display: block;
    aspect-ratio: 1;
    overflow: hidden;
    background: #eef4f0;
  }

  .result-card__image img,
  .result-card__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 220ms ease;
  }

  .result-card:hover .result-card__image img {
    transform: scale(1.04);
  }

  .result-card__content {
    display: grid;
    gap: 10px;
    padding: 14px;
  }

  .result-card__type,
  .result-card__meta {
    margin: 0;
    color: rgba(22, 35, 31, 0.58);
    font-size: 0.78rem;
    font-weight: 800;
  }

  .result-card h3 {
    margin: 0;
    font-size: 1rem;
    line-height: 1.35;
  }

  .result-card h3 a,
  .result-card__link {
    color: inherit;
    text-decoration: none;
  }

  .result-card h3 a:hover,
  .result-card__link:hover {
    color: var(--search-accent);
  }

  .result-card__price {
    display: flex;
    gap: 8px;
    color: var(--search-accent);
    font-weight: 900;
  }

  .result-card__price s {
    color: rgba(22, 35, 31, 0.46);
  }

  .result-card__badge {
    width: fit-content;
    border-radius: 999px;
    padding: 5px 9px;
    font-size: 0.76rem;
    font-weight: 900;
  }

  .result-card__badge--available {
    background: #dcfce7;
    color: #166534;
  }

  .result-card__badge--unavailable {
    background: #ffe4e6;
    color: #9f1239;
  }

  .result-card__excerpt {
    margin: 0;
    color: rgba(22, 35, 31, 0.68);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .result-card__link {
    color: var(--search-accent);
    font-weight: 900;
  }

  .search-pagination {
    display: flex;
    justify-content: center;
    margin-top: 40px;
  }

  .search-empty,
  .search-prompt {
    display: grid;
    justify-items: center;
    gap: 18px;
    border: 1px dashed rgba(20, 89, 75, 0.22);
    border-radius: 8px;
    padding: clamp(42px, 8vw, 72px) 20px;
    text-align: center;
  }

  .search-empty p,
  .search-prompt p {
    margin: 0;
    color: rgba(22, 35, 31, 0.68);
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 989px) {
    .search-form__row {
      grid-template-columns: 1fr;
    }

    .results-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 639px) {
    .search-container {
      width: min(100% - 24px, 1180px);
    }

    .results-grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Search",
  "settings": [
    {
      "type": "range",
      "id": "results_per_page",
      "label": "Results per page",
      "min": 12,
      "max": 48,
      "step": 12,
      "default": 24
    }
  ]
}
{% endschema %}
