<section class="customer-auth page-transition-surface" aria-labelledby="CustomerResetTitle-{{ section.id }}">
  <div class="customer-auth__container">
    <div class="customer-auth__intro">
      <p class="customer-auth__eyebrow">SmartNest account</p>
      <h1 id="CustomerResetTitle-{{ section.id }}">Reset password</h1>
      <p>Create a new password for your customer account.</p>
    </div>

    <div class="customer-auth__panel customer-auth__panel--narrow">
      {% form 'reset_customer_password', class: 'customer-auth__form' %}
        {% if form.errors %}
          <div class="customer-auth__message customer-auth__message--error" role="alert" tabindex="-1">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div class="customer-auth__field">
          <label for="ResetPassword-{{ section.id }}">New password</label>
          <input
            id="ResetPassword-{{ section.id }}"
            type="password"
            name="customer[password]"
            autocomplete="new-password"
            required
            {% if form.errors contains 'password' %}aria-invalid="true"{% endif %}
          >
        </div>

        <div class="customer-auth__field">
          <label for="ResetPasswordConfirmation-{{ section.id }}">Confirm new password</label>
          <input
            id="ResetPasswordConfirmation-{{ section.id }}"
            type="password"
            name="customer[password_confirmation]"
            autocomplete="new-password"
            required
            {% if form.errors contains 'password_confirmation' %}aria-invalid="true"{% endif %}
          >
        </div>

        <button type="submit" class="customer-auth__button">Reset password</button>
      {% endform %}
    </div>
  </div>
</section>

{% stylesheet %}
  .customer-auth {
    --account-accent: #14594b;
    color: #16231f;
    padding-block: clamp(36px, 7vw, 88px);
  }

  .page-transition-surface {
    will-change: opacity, transform;
  }

  .customer-auth__container {
    width: min(760px, calc(100% - 32px));
    margin-inline: auto;
  }

  .customer-auth__intro {
    margin-bottom: 28px;
  }

  .customer-auth__eyebrow {
    margin: 0 0 8px;
    color: var(--account-accent);
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .customer-auth h1 {
    margin: 0 0 12px;
    font-size: clamp(2.1rem, 5vw, 3.6rem);
    line-height: 1;
  }

  .customer-auth__panel,
  .customer-auth__form,
  .customer-auth__field {
    display: grid;
    gap: 14px;
  }

  .customer-auth__panel {
    border: 1px solid rgba(20, 89, 75, 0.14);
    border-radius: 8px;
    background: #ffffff;
    padding: clamp(20px, 4vw, 32px);
    box-shadow: 0 14px 34px rgba(20, 89, 75, 0.08);
  }

  .customer-auth__panel--narrow {
    max-width: 680px;
  }

  .customer-auth__field label {
    font-weight: 900;
  }

  .customer-auth__field input {
    width: 100%;
    min-height: 48px;
    border: 1px solid rgba(20, 89, 75, 0.2);
    border-radius: 8px;
    padding: 12px 14px;
  }

  .customer-auth__button {
    display: inline-flex;
    min-height: 48px;
    align-items: center;
    justify-content: center;
    border: 0;
    border-radius: 8px;
    background: var(--account-accent);
    color: #ffffff;
    cursor: pointer;
    padding: 12px 18px;
    font-weight: 900;
  }

  .customer-auth__message {
    border-radius: 8px;
    padding: 12px 14px;
    line-height: 1.5;
  }

  .customer-auth__message--error {
    background: #ffe4e6;
    color: #9f1239;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Customer reset password",
  "settings": [],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
