{% doc %}
  Renders account navigation links for customer account pages.

  @param {string} [active] - The active account area. Accepted values: account, orders, addresses, profile

  @example
  {% render 'account-nav', active: 'account' %}
{% enddoc %}

{% if shop.customer_accounts_enabled %}
  <nav class="account-nav" aria-label="Customer account">
    <a
      href="{{ routes.account_url }}"
      class="account-nav__link{% if active == 'account' or active == 'orders' or active == 'profile' %} account-nav__link--active{% endif %}"
      {% if active == 'account' or active == 'orders' or active == 'profile' %}aria-current="page"{% endif %}
    >
      Account
    </a>

    <a
      href="{{ routes.account_addresses_url }}"
      class="account-nav__link{% if active == 'addresses' %} account-nav__link--active{% endif %}"
      {% if active == 'addresses' %}aria-current="page"{% endif %}
    >
      Saved addresses
    </a>

    <a href="{{ routes.account_logout_url }}" class="account-nav__link">
      Log out
    </a>
  </nav>
{% endif %}

{% stylesheet %}
  .account-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    align-items: center;
    margin-bottom: 22px;
  }

  .account-nav__link {
    display: inline-flex;
    min-height: 40px;
    align-items: center;
    border: 1px solid rgba(20, 89, 75, 0.18);
    border-radius: 8px;
    color: #14594b;
    padding: 9px 13px;
    font-weight: 900;
    text-decoration: none;
  }

  .account-nav__link:hover,
  .account-nav__link:focus-visible,
  .account-nav__link--active {
    background: #14594b;
    color: #ffffff;
  }
{% endstylesheet %}
