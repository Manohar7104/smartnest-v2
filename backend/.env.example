PORT=3000
NODE_ENV=development

# Shopify store domain without protocol, for example:
# smartnest.myshopify.com
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com

# Admin API access token from a custom app or OAuth app.
# Required scopes: read_orders, write_orders.
SHOPIFY_ADMIN_API_ACCESS_TOKEN=shpat_your_admin_api_access_token

# Latest stable Admin GraphQL API version as of June 23, 2026.
SHOPIFY_API_VERSION=2026-04

# Comma-separated browser origins allowed to call this backend.
# For development you can use your Shopify preview domain and localhost.
CORS_ORIGIN=http://localhost:9292,https://your-store.myshopify.com
